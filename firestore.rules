rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: Check if user is authorized (whitelist)
    function isAuthorized() {
      return request.auth != null && 
             (request.auth.token.email == 'magv.1287@gmail.com' || 
              request.auth.token.email == 'gcgv25@gmail.com');
    }
    
    // Household data - shared between Miguel & Grecia
    match /household/main/{document=**} {
      allow read, write: if isAuthorized();
    }
    
    // Legacy /users collection - keep for backward compatibility but restrict
    match /users/{userId} {
      allow read, write: if isAuthorized() && request.auth.uid == userId;
    }
    
    // Legacy /transactions collection - keep for backward compatibility but restrict
    match /transactions/{transactionId} {
      allow read, write: if isAuthorized();
    }
    
    // Deny all other paths by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
