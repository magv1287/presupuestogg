rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authorized
    function isAuthorized() {
      return request.auth != null 
        && (request.auth.token.email == 'gcgv25@gmail.com' 
        || request.auth.token.email == 'magv.1287@gmail.com');
    }
    
    // Users collection
    match /users/{userId} {
      allow read, write: if isAuthorized() && request.auth.uid == userId;
    }
    
    // Transactions collection
    match /transactions/{transactionId} {
      allow read, write: if isAuthorized();
    }
    
    // Analyses collection (for storing AI analysis results)
    match /analyses/{analysisId} {
      allow read, write: if isAuthorized();
    }
    
    // Periods collection (quincenal analysis)
    match /periods/{userId}/analyses/{periodId} {
      allow read, write: if isAuthorized() && request.auth.uid == userId;
    }
  }
}
